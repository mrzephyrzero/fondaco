# Fondaco configuration (Phase 0 skeleton — surface grows in later phases)

# Password for the demo Postgres container (compose default: fondaco-dev)
POSTGRES_PASSWORD=fondaco-dev

# The app connects as fondaco_ro (SELECT-only, created by
# demo/dataset/init/03_readonly_role.sql; demo-grade password fondaco-ro-dev).
# Set only when running the app outside compose:
# DATABASE_URL=postgresql://fondaco_ro:fondaco-ro-dev@localhost:5432/fondaco

# Integration tests (skipped when unset). On Windows use 127.0.0.1, not
# localhost (IPv6 stall):
# FONDACO_TEST_DSN=postgresql://fondaco_ro:fondaco-ro-dev@localhost:5432/fondaco
# FONDACO_TEST_ADMIN_DSN=postgresql://fondaco:fondaco-dev@localhost:5432/fondaco

# Planner LLM endpoint — any OpenAI-compatible /chat/completions server.
# Compose default: Ollama on the docker host (http://host.docker.internal:11434/v1,
# model qwen2.5-coder:7b). For a cloud API set e.g.:
# FONDACO_LLM_BASE_URL=https://api.anthropic.com/v1
FONDACO_LLM_API_KEY=
# FONDACO_LLM_MODEL=claude-sonnet-5
# Local Ollama instead — zero code changes (documented smoke test, Checkpoint P3):
# FONDACO_LLM_BASE_URL=http://localhost:11434/v1
# FONDACO_LLM_MODEL=llama3.1
# Max plan-generation attempts before failing closed:
# FONDACO_LLM_MAX_ATTEMPTS=2
# Per-request timeout; raise for slow local inference (e.g. 180 for Ollama):
# FONDACO_LLM_TIMEOUT_S=60

# Egress clearance of the single v0 endpoint (see design/label-model.md §5):
FONDACO_EGRESS_CLEARANCE=internal
