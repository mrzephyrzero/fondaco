# Fondaco configuration (Phase 0 skeleton — surface grows in later phases)

# Password for the demo Postgres container (compose default: fondaco-dev)
POSTGRES_PASSWORD=fondaco-dev

# The app connects as fondaco_ro (SELECT-only, created by
# demo/dataset/init/03_readonly_role.sql; demo-grade password fondaco-ro-dev).
# Set only when running the app outside compose:
# DATABASE_URL=postgresql://fondaco_ro:fondaco-ro-dev@localhost:5432/fondaco

# Integration tests (skipped when unset). On Windows use 127.0.0.1, not
# localhost (IPv6 stall):
# FONDACO_TEST_DSN=postgresql://fondaco_ro:fondaco-ro-dev@localhost:5432/fondaco
# FONDACO_TEST_ADMIN_DSN=postgresql://fondaco:fondaco-dev@localhost:5432/fondaco

# Planner selection. 'demo' (default) serves pre-generated fixture plans for
# the scripted questions — keyless, no LLM, works out of the box. Set to 'llm'
# to use a real OpenAI-compatible planner via one of the profiles below.
FONDACO_PLANNER=demo

# Planner LLM endpoint (used only when FONDACO_PLANNER=llm) — any
# OpenAI-compatible /chat/completions server. Two documented profiles;
# sampling params are part of the profile.
#
# Profile A — cloud (default planner): omits FONDACO_LLM_TEMPERATURE, because
# claude-sonnet-5 rejects the deprecated `temperature` param.
FONDACO_LLM_BASE_URL=https://api.anthropic.com/v1
FONDACO_LLM_MODEL=claude-sonnet-5
FONDACO_LLM_API_KEY=
# FONDACO_LLM_TEMPERATURE=omit   # unset or "omit" → the param is not sent
#
# Profile B — local fallback (no API key needed; compose default):
# FONDACO_LLM_BASE_URL=http://host.docker.internal:11434/v1
# FONDACO_LLM_MODEL=qwen2.5-coder:7b
# FONDACO_LLM_TEMPERATURE=0      # pinned for reproducibility
# FONDACO_LLM_TIMEOUT_S=180
#
# Switching profiles requires zero code changes (Checkpoint P3).
# Max plan-generation attempts before failing closed:
# FONDACO_LLM_MAX_ATTEMPTS=2

# Egress clearance of the single v0 endpoint (see design/label-model.md §5):
FONDACO_EGRESS_CLEARANCE=internal

# Guards (Phase 5). Fail behavior is ALWAYS closed: a value below 1 or
# unparsable falls back to the default — a guard cannot be turned off.
# k-threshold: aggregate groups backed by fewer than k rows are dropped.
FONDACO_GUARD_K=5
# Per-session hard cap on executed query steps.
FONDACO_QUERY_BUDGET=20
